<import src="../../template/post-list.wxml" />

<view class="page">
  <!-- 顶部轮播图：热度前三帖子 -->
  <swiper class="banner" indicator-dots autoplay circular interval="3000">
    <block wx:for="{{bannerList}}" wx:key="postId">
      <swiper-item>
        <view class="banner-item" data-post-id="{{item.postId}}" bindtap="onTapBanner">
          <!-- 有封面：显示封面 -->
          <image wx:if="{{item.postImg}}" class="banner-img" src="{{item.postImg}}" mode="aspectFill"></image>

          <!-- 无封面：显示标题 -->
          <view wx:else class="banner-title-card">
            <view class="banner-rank">热度 TOP {{index + 1}}</view>
            <view class="banner-title-text">{{item.title}}</view>
            <view class="banner-info">
              {{item.category}} · 浏览 {{item.view}} · 点赞 {{item.like}}
            </view>
          </view>

          <!-- 有封面时的标题遮罩 -->
          <view wx:if="{{item.postImg}}" class="banner-mask">
            <view class="banner-rank">热度 TOP {{index + 1}}</view>
            <view class="banner-title">{{item.title}}</view>
          </view>
        </view>
      </swiper-item>
    </block>
  </swiper>

  <!-- 搜索框 -->
  <view class="search-box">
    <view class="search-inner">
      <image class="search-icon" src="{{keyword ? '/images/icon/search-active.png' : '/images/icon/search.png'}}" mode="aspectFit"></image>

      <input class="search-input" placeholder="搜索校园帖子" value="{{keyword}}" bindinput="onSearchInput" />
    </view>
  </view>

  <!-- 分类标题 -->
  <view class="category-title">
    <image class="category-title-icon" src="{{currentCategory === '全部' ? '/images/icon/category.png' : '/images/icon/category-active.png'}}" mode="aspectFit"></image>
    <text>分类筛选</text>
  </view>

  <!-- 分类栏 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <block wx:for="{{categoryList}}" wx:key="id">
        <view class="category-item {{currentCategory === item.name ? 'category-active' : ''}}" data-category="{{item.name}}" bindtap="onTapCategory">
          {{item.name}}
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 排序功能区 -->
  <view class="sort-card">
    <view class="sort-row">
      <view class="sort-item">
        <text class="sort-label">时间</text>
        <picker mode="selector" range="{{timeRangeNames}}" value="{{timeRangeIndex}}" bindchange="onTimeRangeChange">
          <view class="sort-picker">{{timeRangeNames[timeRangeIndex]}}</view>
        </picker>
      </view>

      <view class="sort-item">
        <text class="sort-label">排序</text>
        <picker mode="selector" range="{{sortNames}}" value="{{sortIndex}}" bindchange="onSortChange">
          <view class="sort-picker">{{sortNames[sortIndex]}}</view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 热门标题 -->
  <view class="section-title">
    <text>校园热帖</text>
  </view>

  <!-- 帖子列表 -->
  <view class="post-list">
    <template is="postList" data="{{list: showPostList, emptyText: emptyText}}" />
  </view>
</view>