page {
  background-color: #f5f6f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

/* 主体卡片 */
.detail-card {
  padding: 28rpx;
  border-radius: 22rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.post-header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background-color: #eeeeee;
}

.author-box {
  flex: 1;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
}

.author {
  font-size: 30rpx;
  color: #222222;
  font-weight: 500;
}

.date {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999999;
}

.category {
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  background-color: #edf4ff;
  color: #2f80ed;
  font-size: 22rpx;
}

.title {
  margin-top: 30rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: #222222;
  line-height: 56rpx;
}

.post-img {
  width: 100%;
  height: 360rpx;
  margin-top: 24rpx;
  border-radius: 18rpx;
  background-color: #eeeeee;
}

.content {
  margin-top: 26rpx;
  font-size: 30rpx;
  color: #444444;
  line-height: 52rpx;
  white-space: pre-wrap;
}

.count-row {
  display: flex;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eeeeee;
  font-size: 24rpx;
  color: #888888;
}

.count-row text {
  margin-right: 36rpx;
}

/* 操作栏 */
.action-card {
  display: flex;
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
}

.action-item {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0 10rpx;
  border-radius: 36rpx;
  text-align: center;
  background-color: #f1f2f4;
  color: #555555;
  font-size: 28rpx;
}

.action-item.active {
  background-color: #2f80ed;
  color: #ffffff;
}

/* 评论区 */
.comment-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
}

.comment-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #222222;
}

.comment-count {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #999999;
  font-weight: normal;
}

.empty-comment {
  padding: 60rpx 0;
  text-align: center;
  color: #999999;
  font-size: 26rpx;
}

.comment-item {
  display: flex;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #eeeeee;
}

.comment-main {
  flex: 1;
  margin-left: 18rpx;
}

.comment-top {
  display: flex;
  align-items: center;
}

.comment-author {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.comment-date {
  font-size: 22rpx;
  color: #999999;
}

.comment-content {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #555555;
  line-height: 42rpx;
}

/* 底部输入栏 */
.comment-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 18rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 36rpx;
  background-color: #f1f2f4;
  font-size: 28rpx;
  color: #333333;
}

.send-btn {
  width: 132rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 18rpx;
  padding: 0;
  border-radius: 36rpx;
  background-color: #2f80ed;
  color: #ffffff;
  font-size: 28rpx;
}

.send-btn::after {
  border: none;
}

.loading {
  padding-top: 200rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}