<view class="page" wx:if="{{post}}">
  <!-- 帖子主体 -->
  <view class="detail-card">
    <view class="post-header">
      <view
        class="avatar-wrap"
        catchtap="onTapAuthor"
        data-author-id="{{post.authorId}}"
        data-is-current-user="{{post.authorInfo.isCurrentUser}}"
        data-author-name="{{post.author}}"
      >
        <image class="avatar" src="{{post.avatar || '/images/avatar/default.png'}}" mode="aspectFill"></image>
      </view>

      <view class="author-box">
        <text class="author">{{post.author}}</text>
        <text class="date">{{post.date}}</text>
      </view>

      <text class="category">{{post.category}}</text>
    </view>

    <view class="title">{{post.title}}</view>

    <image wx:if="{{post.postImg}}" class="post-img" src="{{post.postImg}}" mode="aspectFill"></image>

    <view class="content">{{post.content}}</view>

    <view class="count-row">
      <view class="count-item">
        <image class="count-icon" src="/images/icon/view.png" mode="aspectFit"></image>
        <text>浏览 {{post.view}}</text>
      </view>

      <view class="count-item">
        <image class="count-icon" src="{{post.isLiked ? '/images/icon/like-active.png' : '/images/icon/like.png'}}" mode="aspectFit"></image>
        <text>点赞 {{post.like}}</text>
      </view>

      <view class="count-item">
        <image class="count-icon" src="{{post.isCollected ? '/images/icon/collect-active.png' : '/images/icon/collect.png'}}" mode="aspectFit"></image>
        <text>收藏 {{post.collect || 0}}</text>
      </view>

      <view class="count-item">
        <image class="count-icon" src="/images/icon/comment.png" mode="aspectFit"></image>
        <text>评论 {{post.commentCount}}</text>
      </view>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="action-card">
    <view class="action-item {{post.isLiked ? 'active' : ''}}" bindtap="onTapLike">
      <image class="action-icon" src="{{post.isLiked ? '/images/icon/like-active.png' : '/images/icon/like.png'}}" mode="aspectFit"></image>
      <text>{{post.isLiked ? '已点赞' : '点赞'}}</text>
    </view>

    <view class="action-item {{post.isCollected ? 'active' : ''}}" bindtap="onTapCollect">
      <image class="action-icon" src="{{post.isCollected ? '/images/icon/collect-active.png' : '/images/icon/collect.png'}}" mode="aspectFit"></image>
      <text>{{post.isCollected ? '已收藏' : '收藏'}}</text>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-card">
    <view class="comment-title">
      <text>评论</text>
      <text class="comment-count">{{commentList.length}}</text>
    </view>

    <view wx:if="{{commentList.length === 0}}" class="empty-comment">
      暂无评论，来写第一条评论吧
    </view>

    <block wx:for="{{commentList}}" wx:key="commentId">
      <view class="comment-item">
        <image class="comment-avatar" src="{{item.avatar || '/images/avatar/default.png'}}" mode="aspectFill"></image>

        <view class="comment-main">
          <view class="comment-top">
            <text class="comment-author">{{item.author}}</text>
            <text class="comment-date">{{item.date}}</text>
          </view>

          <view class="comment-content">{{item.content}}</view>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部评论输入栏 -->
  <view class="comment-input-bar">
    <input class="comment-input" placeholder="写一条评论" value="{{commentText}}" bindinput="onCommentInput" />
    <button class="send-btn" bindtap="onSubmitComment">发送</button>
  </view>
</view>

<view wx:else class="loading">
  正在加载帖子
</view>
