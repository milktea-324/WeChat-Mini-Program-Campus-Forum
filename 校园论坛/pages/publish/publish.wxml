<view class="page">
  <view class="form-card">
    <view class="form-title">
      <image class="form-title-icon" src="/images/icon/edit-active.png" mode="aspectFit"></image>
      <text>发布校园帖子</text>
    </view>

    <!-- 标题 -->
    <view class="form-item">
      <view class="label">标题</view>
      <input class="input" placeholder="请输入帖子标题" value="{{title}}" bindinput="onTitleInput" maxlength="30" />
      <view class="count">{{title.length}} / 30</view>
    </view>

    <!-- 分类 -->
    <view class="form-item">
      <view class="label">分类</view>
      <picker mode="selector" range="{{categoryNames}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-box">
          <text>{{categoryNames[categoryIndex]}}</text>
          <text class="picker-arrow">请选择</text>
        </view>
      </picker>
    </view>

    <!-- 内容 -->
    <view class="form-item">
      <view class="label">内容</view>
      <textarea class="textarea" placeholder="请输入帖子内容" value="{{content}}" bindinput="onContentInput" maxlength="300"></textarea>
      <view class="count">{{content.length}} / 300</view>
    </view>

    <!-- 联系方式，可选 -->
    <view class="form-item">
      <view class="label">联系方式 <text class="optional">选填</text></view>
      <input class="input" placeholder="例如 QQ、微信、手机号，二手交易或失物招领可填写" value="{{contact}}" bindinput="onContactInput" />
    </view>

    <!-- 封面 -->
    <view class="form-item">
      <view class="label">帖子封面 <text class="optional">选填</text></view>

      <view wx:if="{{postImg}}" class="cover-preview">
        <image class="cover-img" src="{{postImg}}" mode="aspectFill"></image>
        <view class="cover-delete" bindtap="onDeleteCover">删除封面</view>
      </view>

      <view wx:else class="cover-upload" bindtap="onChooseCover">
        <image class="cover-upload-icon" src="/images/icon/edit.png" mode="aspectFit"></image>
        <text>选择封面图片</text>
      </view>
    </view>

    <!-- 图片说明 -->
    <view class="tip-box">
      封面为选填项。未选择封面时，帖子列表右侧不会显示图片区域。
    </view>

    <button class="submit-btn" bindtap="onSubmit">发布</button>
    <button class="reset-btn" bindtap="onReset">清空</button>
  </view>
</view>