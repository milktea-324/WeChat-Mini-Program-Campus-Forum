page {
  background-color: #f5f6f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.form-card {
  padding: 30rpx;
  border-radius: 24rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.form-title {
  margin-bottom: 30rpx;
  font-size: 38rpx;
  font-weight: bold;
  color: #222222;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.optional {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
}

.input {
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background-color: #f5f6f7;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 260rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background-color: #f5f6f7;
  font-size: 28rpx;
  color: #333333;
  line-height: 42rpx;
  box-sizing: border-box;
}

.count {
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: #999999;
}

.picker-box {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background-color: #f5f6f7;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.picker-box text:first-child {
  flex: 1;
}

.picker-arrow {
  color: #999999;
  font-size: 24rpx;
}

.tip-box {
  margin-bottom: 28rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: #edf4ff;
  color: #2f80ed;
  font-size: 24rpx;
  line-height: 38rpx;
}

.submit-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  background-color: #2f80ed;
  color: #ffffff;
  font-size: 30rpx;
}

.submit-btn::after,
.reset-btn::after {
  border: none;
}

.reset-btn {
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 20rpx;
  border-radius: 40rpx;
  background-color: #f1f2f4;
  color: #666666;
  font-size: 28rpx;
}