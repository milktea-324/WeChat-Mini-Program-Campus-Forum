@import "../../template/post-list.wxss";

page {
  background-color: #f5f6f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 用户信息 */
.user-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-radius: 24rpx;
  background-color: #2f80ed;
  color: #ffffff;
}

.user-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background-color: #eeeeee;
}

.user-info {
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
}

.desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

/* 统计卡片 */
.stat-card {
  display: flex;
  margin-top: 22rpx;
  padding: 28rpx 0;
  border-radius: 22rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 38rpx;
  font-weight: bold;
  color: #222222;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888888;
}

/* 切换栏 */
.tab-card {
  display: flex;
  margin-top: 22rpx;
  padding: 10rpx;
  border-radius: 22rpx;
  background-color: #ffffff;
}

.tab-item {
  flex: 1;
  min-height: 92rpx;
  padding: 10rpx 0;
  border-radius: 34rpx;
  font-size: 26rpx;
  color: #666666;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-main {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.tab-num {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 28rpx;
}

.tab-active {
  background-color: #edf4ff;
  color: #2f80ed;
}

.tab-active .tab-num {
  color: #2f80ed;
  font-weight: 500;
}

/* 列表 */
.list-card {
  margin-top: 22rpx;
}

.post-item {
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.post-top {
  display: flex;
  align-items: center;
}

.post-category {
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  background-color: #edf4ff;
  color: #2f80ed;
  font-size: 22rpx;
}

.post-date {
  flex: 1;
  text-align: right;
  color: #999999;
  font-size: 22rpx;
}

.post-title {
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #222222;
  line-height: 46rpx;
}

.post-content {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666666;
  line-height: 40rpx;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-bottom {
  display: flex;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eeeeee;
  color: #888888;
  font-size: 24rpx;
}

.post-bottom text {
  margin-right: 30rpx;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

/* 2026年6月23日13点38分-个人页面-细化功能-样式 */
/* 搜索框 */
.search-box {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background-color: #ffffff;
}

.search-inner {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 36rpx;
  background-color: #f1f2f4;
  box-sizing: border-box;
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  background-color: transparent;
  font-size: 28rpx;
  color: #333333;
}


/* 分类栏 */
.category-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
  background-color: #ffffff;
  border-radius: 22rpx;
  padding: 18rpx 0;
}

.category-list {
  display: flex;
  padding: 0 20rpx;
}

.category-item {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  margin-right: 18rpx;
  border-radius: 30rpx;
  background-color: #f1f2f4;
  color: #555555;
  font-size: 26rpx;
}

.category-active {
  background-color: #2f80ed;
  color: #ffffff;
}

/* 当前筛选提示 */
.filter-tip {
  margin-top: 22rpx;
  padding: 0 6rpx;
  font-size: 24rpx;
  color: #888888;
}

/* 分类标题 */
.category-title {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 0 6rpx 12rpx;
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
}

.category-title-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 10rpx;
}

/* 排序功能区 */
.sort-card {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background-color: #ffffff;
}

.sort-row {
  display: flex;
  gap: 18rpx;
}

.sort-item {
  flex: 1;
  display: flex;
  align-items: center;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 34rpx;
  background-color: #f5f6f7;
  box-sizing: border-box;
}

.sort-label {
  margin-right: 12rpx;
  color: #666666;
  font-size: 24rpx;
}

.sort-icon {
  order: -1;
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.sort-picker {
  color: #2f80ed;
  font-size: 24rpx;
}
