<view class="page">
  <!-- 用户信息 -->
  <view class="user-card">
    <image class="user-avatar" src="{{user.avatar}}" mode="aspectFill"></image>

    <view class="user-info">
      <view class="nickname">{{user.nickname}}</view>
      <view class="desc">校园生活圈用户</view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stat-card">
    <view class="stat-item">
      <view class="stat-num">{{myPostList.length}}</view>
      <view class="stat-label">我的发布</view>
    </view>

    <view class="stat-item">
      <view class="stat-num">{{collectList.length}}</view>
      <view class="stat-label">我的收藏</view>
    </view>

    <view class="stat-item">
      <view class="stat-num">{{likeList.length}}</view>
      <view class="stat-label">我的点赞</view>
    </view>
  </view>

  <!-- 发布 / 收藏 / 点赞切换栏 -->
  <view class="tab-card">
  <view 
    class="tab-item {{currentTab === 'my' ? 'tab-active' : ''}}"
    data-tab="my"
    bindtap="onChangeTab"
  >
    <image 
      class="tab-icon" 
      src="{{currentTab === 'my' ? '/images/icon/edit-active.png' : '/images/icon/edit.png'}}" 
      mode="aspectFit"
    ></image>
    <text>我的发布</text>
  </view>

  <view 
    class="tab-item {{currentTab === 'collect' ? 'tab-active' : ''}}"
    data-tab="collect"
    bindtap="onChangeTab"
  >
    <image 
      class="tab-icon" 
      src="{{currentTab === 'collect' ? '/images/icon/collect-active.png' : '/images/icon/collect.png'}}" 
      mode="aspectFit"
    ></image>
    <text>我的收藏</text>
  </view>

  <view 
    class="tab-item {{currentTab === 'like' ? 'tab-active' : ''}}"
    data-tab="like"
    bindtap="onChangeTab"
  >
    <image 
      class="tab-icon" 
      src="{{currentTab === 'like' ? '/images/icon/like-active.png' : '/images/icon/like.png'}}" 
      mode="aspectFit"
    ></image>
    <text>我的点赞</text>
  </view>
</view>

  <!-- 搜索框 -->
  <view class="search-box">
  <view class="search-inner">
    <image 
      class="search-icon" 
      src="{{keyword ? '/images/icon/search-active.png' : '/images/icon/search.png'}}" 
      mode="aspectFit"
    ></image>

    <input 
      class="search-input"
      placeholder="搜索当前列表中的帖子"
      value="{{keyword}}"
      bindinput="onSearchInput"
    />
  </view>
</view>

<!-- 分类标题 -->
<view class="category-title">
  <image 
    class="category-title-icon" 
    src="{{currentCategory === '全部' ? '/images/icon/category.png' : '/images/icon/category-active.png'}}" 
    mode="aspectFit"
  ></image>
  <text>分类筛选</text>
</view>

  <!-- 分类栏 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <block wx:for="{{categoryList}}" wx:key="id">
        <view 
          class="category-item {{currentCategory === item.name ? 'category-active' : ''}}"
          data-category="{{item.name}}"
          bindtap="onTapCategory"
        >
          {{item.name}}
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 当前筛选提示 -->
  <view class="filter-tip">
    <text>{{tabTitle}}</text>
    <text wx:if="{{currentCategory !== '全部'}}"> · {{currentCategory}}</text>
    <text wx:if="{{keyword !== ''}}"> · 搜索：{{keyword}}</text>
  </view>

  <!-- 列表 -->
  <view class="list-card">
    <block wx:if="{{showList.length > 0}}">
      <block wx:for="{{showList}}" wx:key="postId">
        <view class="post-item" data-post-id="{{item.postId}}" bindtap="onTapPost">
          <view class="post-top">
            <text class="post-category">{{item.category}}</text>
            <text class="post-date">{{item.date}}</text>
          </view>

          <view class="post-title">{{item.title}}</view>

          <view class="post-content">{{item.content}}</view>

          <view class="post-bottom">
            <text>浏览 {{item.view}}</text>
            <text>点赞 {{item.like}}</text>
            <text>评论 {{item.commentCount}}</text>
          </view>
        </view>
      </block>
    </block>

    <view wx:else class="empty">
      {{emptyText}}
    </view>
  </view>
</view>