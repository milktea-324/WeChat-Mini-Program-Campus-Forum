@import "../../template/post-list.wxss";

page {
  background-color: #f5f6f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.profile-card {
  display: flex;
  padding: 32rpx;
  border-radius: 24rpx;
  background-color: #2f80ed;
  color: #ffffff;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: #eeeeee;
  flex-shrink: 0;
}

.profile-main {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 38rpx;
  font-weight: bold;
  line-height: 48rpx;
}

.bio {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 38rpx;
  opacity: 0.9;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.profile-tag {
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.stat-card {
  display: flex;
  margin-top: 22rpx;
  padding: 28rpx 0;
  border-radius: 22rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 34rpx;
  font-weight: bold;
  color: #222222;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #888888;
}

.meta-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.meta-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
}

.interest-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.interest-item {
  margin-right: 16rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  background-color: #edf4ff;
  color: #2f80ed;
  font-size: 24rpx;
}

.section-title {
  padding: 30rpx 6rpx 0;
  font-size: 34rpx;
  font-weight: bold;
  color: #222222;
}

.post-list {
  margin-top: 0;
}

.loading {
  padding-top: 200rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}
