@import "../../template/post-list.wxss";

page {
  background-color: #f5f6f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.profile-card {
  padding: 32rpx;
  border-radius: 24rpx;
  background-color: #2f80ed;
  color: #ffffff;
}

.profile-top {
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: #eeeeee;
  flex-shrink: 0;
}

.profile-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.nickname {
  font-size: 38rpx;
  font-weight: bold;
  line-height: 48rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  opacity: 0.86;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bio {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 38rpx;
  opacity: 0.9;

  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.profile-tag {
  max-width: 190rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-card {
  display: flex;
  margin-top: 22rpx;
  padding: 28rpx 0;
  border-radius: 22rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 34rpx;
  font-weight: bold;
  color: #222222;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #888888;
}

.content-tabs {
  display: flex;
  margin-top: 22rpx;
  padding: 10rpx;
  border-radius: 22rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.content-tab {
  flex: 1;
  height: 70rpx;
  border-radius: 18rpx;
  color: #666666;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-tab-active {
  background-color: #edf4ff;
  color: #2f80ed;
  font-weight: bold;
}

.post-list {
  margin-top: 0;
}

.comment-list {
  margin-top: 22rpx;
}

.comment-card {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.comment-card:first-child {
  margin-top: 0;
}

.comment-content {
  color: #333333;
  font-size: 29rpx;
  line-height: 44rpx;
  word-break: break-all;
}

.comment-post {
  margin-top: 16rpx;
  color: #2f80ed;
  font-size: 25rpx;
  line-height: 36rpx;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.comment-date {
  margin-top: 12rpx;
  color: #999999;
  font-size: 23rpx;
}

.comment-empty {
  padding: 120rpx 0;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.comment-empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 18rpx;
  opacity: 0.68;
}

.loading {
  padding-top: 200rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}
