<import src="../../template/post-list.wxml" />

<view class="page" wx:if="{{user}}">
  <view class="profile-card">
    <view class="profile-top">
      <image class="profile-avatar" src="{{user.avatar || '/images/avatar/default.png'}}" mode="aspectFill"></image>

      <view class="profile-main">
        <view class="nickname">{{user.nickname}}</view>
        <view class="profile-meta">{{user.grade}} · {{user.department}} · {{user.roleName}}</view>
        <view class="bio">{{user.bio}}</view>
      </view>
    </view>

    <view class="tag-row">
      <block wx:for="{{user.tags}}" wx:key="*this">
        <view class="profile-tag">{{item}}</view>
      </block>
    </view>
  </view>

  <view class="stat-card">
    <view class="stat-item">
      <view class="stat-num">{{user.stats.postCount}}</view>
      <view class="stat-label">发布</view>
    </view>

    <view class="stat-item">
      <view class="stat-num">{{user.stats.commentCount}}</view>
      <view class="stat-label">评论</view>
    </view>

    <view class="stat-item">
      <view class="stat-num">{{user.stats.viewCount}}</view>
      <view class="stat-label">浏览</view>
    </view>

    <view class="stat-item">
      <view class="stat-num">{{user.stats.likeCount}}</view>
      <view class="stat-label">点赞</view>
    </view>

    <view class="stat-item">
      <view class="stat-num">{{user.stats.collectCount}}</view>
      <view class="stat-label">收藏</view>
    </view>
  </view>

  <view class="content-tabs">
    <view class="content-tab {{activeTab === 'posts' ? 'content-tab-active' : ''}}" data-tab="posts" bindtap="onChangeTab">
      TA 的发布
    </view>
    <view class="content-tab {{activeTab === 'comments' ? 'content-tab-active' : ''}}" data-tab="comments" bindtap="onChangeTab">
      TA 的评论
    </view>
  </view>

  <view wx:if="{{activeTab === 'posts'}}" class="post-list">
    <template is="postList" data="{{list: authorPosts, emptyText: emptyText}}" />
  </view>

  <view wx:elif="{{activeTab === 'comments'}}" class="comment-list">
    <block wx:if="{{authorComments && authorComments.length > 0}}">
      <block wx:for="{{authorComments}}" wx:key="commentId">
        <view
          class="comment-card"
          bindtap="onTapComment"
          data-post-id="{{item.postId}}"
          data-available="{{item.postAvailable}}"
        >
          <view class="comment-content">{{item.content}}</view>
          <view class="comment-post">评论了帖子《{{item.postTitle}}》</view>
          <view class="comment-date">{{item.date}}</view>
        </view>
      </block>
    </block>

    <view wx:else class="comment-empty">
      <image class="comment-empty-icon" src="/images/icon/empty.png" mode="aspectFit"></image>
      <view>{{emptyText}}</view>
    </view>
  </view>
</view>

<view wx:else class="loading">
  正在加载作者资料
</view>
