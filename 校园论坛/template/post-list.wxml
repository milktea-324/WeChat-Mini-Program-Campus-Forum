<template name="postList">
  <view class="forum-list">
    <block wx:if="{{list && list.length > 0}}">
      <block wx:for="{{list}}" wx:key="postId">
        <view 
          class="forum-card" 
          bindtap="onTapPost" 
          data-post-id="{{item.postId}}"
        >
          <!-- 用户信息 -->
          <view class="forum-user">
            <view
              class="forum-avatar-wrap"
              catchtap="onTapAuthor"
              data-author-id="{{item.authorId}}"
              data-is-current-user="{{item.displayIsCurrentUser || item.authorInfo.isCurrentUser}}"
              data-author-name="{{item.displayAuthorName || item.authorName || item.author}}"
              data-avatar="{{item.displayAuthorAvatar || item.authorAvatar || item.avatar}}"
            >
              <image class="forum-avatar" src="{{item.displayAuthorAvatar || item.authorAvatar || item.avatar || '/images/avatar/default.png'}}" mode="aspectFill"></image>
            </view>

            <view class="forum-user-info">
              <text class="forum-author">{{item.displayAuthorName || item.authorName || item.author}}</text>
              <text class="forum-date">{{item.displayTime || item.date}}</text>
            </view>

            <text class="forum-category">{{item.displayCategoryName || item.categoryName || item.category}}</text>
          </view>

          <!-- 帖子主体 -->
          <view class="forum-main {{(item.displayCoverUrl || item.coverUrl || item.postImg) ? '' : 'forum-main-no-cover'}}">
            <view class="forum-text">
              <text class="forum-title">{{item.title}}</text>
              <text class="forum-content">{{item.content || item.summary}}</text>
            </view>

            <image 
              wx:if="{{item.displayCoverUrl || item.coverUrl || item.postImg}}"
              class="forum-cover" 
              src="{{item.displayCoverUrl || item.coverUrl || item.postImg}}"
              mode="aspectFill"
            ></image>
          </view>

          <!-- 底部统计 -->
          <view class="forum-bottom">
            <view class="forum-count">
              <image class="forum-count-icon" src="/images/icon/view.png" mode="aspectFit"></image>
              <text>{{item.displayViewCount || item.view || 0}}</text>
            </view>

            <view class="forum-count">
              <image 
                class="forum-count-icon" 
                src="{{(item.displayIsLiked || item.isLiked) ? '/images/icon/like-active.png' : '/images/icon/like.png'}}"
                mode="aspectFit"
              ></image>
              <text>{{item.displayLikeCount || item.like || 0}}</text>
            </view>

            <view class="forum-count">
              <image 
                class="forum-count-icon" 
                src="{{(item.displayIsCollected || item.isCollected) ? '/images/icon/collect-active.png' : '/images/icon/collect.png'}}"
                mode="aspectFit"
              ></image>
              <text>{{item.displayCollectCount || item.collect || 0}}</text>
            </view>

            <view class="forum-count">
              <image class="forum-count-icon" src="/images/icon/comment.png" mode="aspectFit"></image>
              <text>{{item.displayCommentCount || item.commentCount || 0}}</text>
            </view>
          </view>
        </view>
      </block>
    </block>

    <view wx:else class="forum-empty">
      <image class="forum-empty-icon" src="/images/icon/empty.png" mode="aspectFit"></image>
      <view>{{emptyText || '暂无帖子'}}</view>
    </view>
  </view>
</template>
